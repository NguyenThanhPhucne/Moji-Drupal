# ─── Database ───────────────────────────────────────────────────────────────
# ⚠️  Code uses MONGODB_CONNECTIONSTRING (NOT MONGODB_URI)
MONGODB_CONNECTIONSTRING=mongodb://localhost:27017/moji_chat

# Redis (used for caching & pub-sub)
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
CLIENT_URL=https://moji-drupal-frontend.vercel.app
CLIENT_URLS=https://moji-drupal-frontend.vercel.app,https://phucnt-open-crm.training.weebpal.com,http://localhost:5173

# ─── Auth & JWT ──────────────────────────────────────────────────────────────
# ⚠️  Code uses ACCESS_TOKEN_SECRET (NOT JWT_SECRET)
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_COOKIE_SECURE=true
REFRESH_TOKEN_TTL_MS=604800000
REFRESH_TOKEN_ABSOLUTE_TTL_MS=2592000000

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_MAX_PER_USER=5
SESSION_STRICT_FINGERPRINT=false

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Drupal Integration ──────────────────────────────────────────────────────
DRUPAL_API_URL=https://phucnt-open-crm.training.weebpal.com
DRUPAL_AUTH_SIGNIN_URL=https://phucnt-open-crm.training.weebpal.com/user/login
DRUPAL_SSO_SECRET=your_drupal_sso_secret_here
DRUPAL_DB_HOST=localhost
DRUPAL_DB_PORT=3306
DRUPAL_DB_USER=root
DRUPAL_DB_PASSWORD=your_mysql_password
DRUPAL_DB_NAME=drupal

# ─── Feature Flags (0–100 rollout percentage) ────────────────────────────────
FF_KEYBOARD_POWER_SHORTCUTS_PERCENT=100
FF_NOTIFICATION_PRIORITY_CENTER_PERCENT=100
FF_REALTIME_EVENT_DEDUPE_ORDERING_PERCENT=100
FF_REALTIME_SNAPSHOT_DELTA_PERCENT=100

# ─── Link Preview ────────────────────────────────────────────────────────────
LINK_PREVIEW_TIMEOUT_MS=5000
LINK_PREVIEW_MAX_REDIRECTS=3
LINK_PREVIEW_MAX_HTML_BYTES=524288

# ─── Message Expiry Cleanup Worker ───────────────────────────────────────────
MESSAGE_EXPIRY_CLEANUP_WORKER_ENABLED=true
MESSAGE_EXPIRY_CLEANUP_INTERVAL_MS=60000
MESSAGE_EXPIRY_CLEANUP_BATCH_SIZE=100
MESSAGE_EXPIRY_CLEANUP_MAX_BATCHES=10
MESSAGE_DEPENDENT_CLEANUP_MODE=soft

# ─── Message Compensation Worker ─────────────────────────────────────────────
MESSAGE_CLEANUP_COMPENSATION_WORKER_ENABLED=true
MESSAGE_CLEANUP_COMPENSATION_WORKER_INTERVAL_MS=300000
MESSAGE_CLEANUP_COMPENSATION_BATCH_SIZE=50
MESSAGE_CLEANUP_COMPENSATION_MAX_RETRIES=3
MESSAGE_CLEANUP_COMPENSATION_BACKOFF_BASE_MS=1000

# ─── Dev Only ────────────────────────────────────────────────────────────────
ALLOW_DEV_FRIENDSHIP_BYPASS=false
