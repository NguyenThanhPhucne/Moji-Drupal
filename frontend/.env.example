# Frontend environment template
# Copy this file to .env.development or .env.production and customize values.

# API Endpoints
VITE_DRUPAL_API=/api/drupal
VITE_NODE_API=/api
VITE_SOCKET_URL=http://localhost:5001

# OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Feature Flags (set to "true" to enable)
VITE_FF_KEYBOARD_POWER_SHORTCUTS=true
VITE_FF_NOTIFICATION_PRIORITY_CENTER=true
VITE_FF_REALTIME_EVENT_DEDUPE_ORDERING=true
VITE_FF_REALTIME_SNAPSHOT_DELTA_RESYNC=true
